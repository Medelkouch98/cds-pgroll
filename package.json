{
  "name": "@cds-pgroll/postgres",
  "version": "1.0.5",
  "description": "Hybrid schema migration library for SAP CAP + PostgreSQL. Complements @cap-js/postgres with DROP, RENAME, and destructive DDL operations via pgroll-compatible migrations.",
  "main": "src/index.js",
  "bin": {
    "cds-pgroll": "bin/cds-pgroll.js",
    "cds-pgroll-run": "bin/run-pgroll.js"
  },
  "scripts": {
    "test": "jest --testTimeout=15000",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ bin/ test/",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "sap",
    "cap",
    "cds",
    "postgres",
    "postgresql",
    "pgroll",
    "migration",
    "schema-evolution",
    "btp",
    "cloud-foundry"
  ],
  "author": "Mohammed El kouch",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Medelkouch98/cds-pgroll.git"
  },
  "homepage": "https://github.com/Medelkouch98/cds-pgroll#readme",
  "bugs": {
    "url": "https://github.com/Medelkouch98/cds-pgroll/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "pg": "^8.13.0"
  },
  "peerDependencies": {
    "@cap-js/postgres": ">=1",
    "@sap/cds": ">=7"
  },
  "peerDependenciesMeta": {
    "@sap/cds": {
      "optional": false
    },
    "@cap-js/postgres": {
      "optional": true
    }
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "jest": "^30.0.0",
    "semantic-release": "^24.2.9"
  },
  "files": [
    "src/",
    "bin/",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "CHANGELOG.md"
        }
      ],
      "@semantic-release/npm",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "package-lock.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ],
      "@semantic-release/github"
    ]
  }
}
